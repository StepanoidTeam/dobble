{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null",

        "players": {
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('rooms/' + $roomCode + '/hostUid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['displayName', 'ready', 'score', 'cardsWon', 'connected', 'joinedAt'])"
          }
        },

        "rounds": {
          "$roundIndex": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['winnerId', 'symbol', 'timestamp']) && newData.child('winnerId').val() === auth.uid"
          }
        },

        "game": {
          ".write": "auth != null && root.child('rooms/' + $roomCode + '/hostUid').val() === auth.uid"
        },

        "status": {
          ".write": "auth != null && (root.child('rooms/' + $roomCode + '/hostUid').val() === auth.uid || newData.val() === 'finished')"
        }
      }
    },

    "matchmaking": {
      ".read": "auth != null",
      "$roomCode": {
        ".write": "auth != null"
      }
    }
  }
}